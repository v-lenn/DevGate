[
  {
    "name": "AWS Access Key ID",
    "pattern": "AKIA[0-9A-Z]{16}"
  },
  {
    "name": "Stripe Live Key",
    "pattern": "sk_live_[0-9a-zA-Z]{24}"
  },
  {
    "name": "Stripe Restricted API Key",
    "pattern": "rk_live_[0-9a-zA-Z]{24}"
  },
  {
    "name": "Slack Token",
    "pattern": "xox[bapr]-[0-9a-zA-Z]{10,}-?[0-9a-zA-Z]{10,}"
  },
  {
    "name": "Slack Token (Precise)",
    "pattern": "(xox[p|b|o|a]-[0-9]{12}-[0-9]{12}-[0-9]{12}-[a-z0-9]{32})"
  },
  {
    "name": "GitHub Personal Access Token",
    "pattern": "gh[opr]_[0-9a-zA-Z]{36,255}"
  },
  {
    "name": "GitHub Fine-Grained Personal Access Token",
    "pattern": "github_pat_[a-zA-Z0-9_]{82}"
  },
  {
    "name": "GitHub OAuth Key",
    "pattern": "[g|G][i|I][t|T][h|H][u|U][b|B].*['|\"][0-9a-zA-Z]{35,40}['|\"]"
  },
  {
    "name": "Google API Key",
    "pattern": "AIza[0-9A-Za-z\\-_]{35}"
  },
  {
    "name": "Google OAuth Client ID",
    "pattern": "[0-9]+-[0-9A-Za-z_]{32}\\.apps\\.googleusercontent\\.com"
  },
  {
    "name": "Google OAuth Access Token",
    "pattern": "ya29\\.[0-9A-Za-z\\-_]+"
  },
  {
    "name": "Google GCP Service Account",
    "pattern": "\"type\": \"service_account\""
  },
  {
    "name": "Cloudinary URL",
    "pattern": "cloudinary://.*"
  },
  {
    "name": "Firebase URL",
    "pattern": ".*firebaseio\\.com"
  },
  {
    "name": "Private Key Header",
    "pattern": "-----BEGIN [A-Z ]+ PRIVATE KEY-----"
  },
  {
    "name": "SSH Private Key Header",
    "pattern": "-----BEGIN (RSA|OPENSSH|DSA|EC) PRIVATE KEY-----"
  },
  {
    "name": "PGP Private Key Block",
    "pattern": "-----BEGIN PGP PRIVATE KEY BLOCK-----"
  },
  {
    "name": "Discord Bot Token",
    "pattern": "[a-zA-Z0-9_-]{23,28}\\.[a-zA-Z0-9_-]{6}\\.[a-zA-Z0-9_-]{27}"
  },
  {
    "name": "Discord Webhook URL",
    "pattern": "https://(discord|discordapp)\\.com/api/webhooks/[0-9]+/[a-zA-Z0-9_-]+"
  },
  {
    "name": "JWT Token",
    "pattern": "eyJ[a-zA-Z0-9_-]{2,}\\.eyJ[a-zA-Z0-9_-]{2,}\\.[a-zA-Z0-9_-]{2,}"
  },
  {
    "name": "Heroku API Key",
    "pattern": "(?i)heroku.*[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}"
  },
  {
    "name": "Twilio Account SID",
    "pattern": "AC[0-9a-fF]{32}"
  },
  {
    "name": "Twilio API Key",
    "pattern": "SK[0-9a-fA-F]{32}"
  },
  {
    "name": "SendGrid API Key",
    "pattern": "SG\\.[a-zA-Z0-9_-]{22}\\.[a-zA-Z0-9_-]{43}"
  },
  {
    "name": "Mailgun API Key",
    "pattern": "key-[0-9a-zA-Z]{32}"
  },
  {
    "name": "MailChimp API Key",
    "pattern": "[0-9a-f]{32}-us[0-9]{1,2}"
  },
  {
    "name": "npm Registry Auth Token",
    "pattern": "//registry\\.npmjs\\.org/:_authToken=[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}"
  },
  {
    "name": "NPM Granular Access Token",
    "pattern": "npm_[a-zA-Z0-9]{36}"
  },
  {
    "name": "PyPI API Token",
    "pattern": "pypi-AgEIcHlwaS5vcmc[0-9A-Za-z-_]+"
  },
  {
    "name": "Square Access Token",
    "pattern": "EAAA[a-zA-Z0-9_-]{60}"
  },
  {
    "name": "Square Personal Access Token",
    "pattern": "sq0atp-[0-9A-Za-z\\-_]{22}"
  },
  {
    "name": "Square OAuth Secret",
    "pattern": "sq0csp-[0-9A-Za-z\\-_]{43}"
  },
  {
    "name": "Telegram Bot Token",
    "pattern": "[0-9]{9,10}:[a-zA-Z0-9_-]{35}"
  },
  {
    "name": "Slack Webhook URL",
    "pattern": "https://hooks\\.slack\\.com/services/[T][A-Z0-9_]{8}/[B][A-Z0-9_]{8}/[a-zA-Z0-9_]{24}"
  },
  {
    "name": "Amazon MWS Auth Token",
    "pattern": "amzn\\.mws\\.[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
  },
  {
    "name": "Facebook Access Token",
    "pattern": "EAACEdEose0cBA[0-9A-Za-z]+"
  },
  {
    "name": "Facebook OAuth Secret",
    "pattern": "[f|F][a|A][c|C][e|E][b|B][o|O][o|O][k|K].*['|\"][0-9a-f]{32}['|\"]"
  },
  {
    "name": "Generic API Key",
    "pattern": "[a|A][p|P][i|I][_]?[k|K][e|E][y|Y].*['|\"][0-9a-zA-Z]{32,45}['|\"]"
  },
  {
    "name": "Generic Secret",
    "pattern": "[s|S][e|E][c|C][r|R][e|E][t|T].*['|\"][0-9a-zA-Z]{32,45}['|\"]"
  },
  {
    "name": "PayPal Braintree Access Token",
    "pattern": "access_token\\$production\\$[0-9a-z]{16}\\$[0-9a-f]{32}"
  },
  {
    "name": "Picatic API Key",
    "pattern": "sk_live_[0-9a-z]{32}"
  },
  {
    "name": "Password in URL",
    "pattern": "[a-zA-Z]{3,10}://[^/\\s:@]{3,20}:[^/\\s:@]{3,20}@.{1,100}[\"'\\s]"
  },
  {
    "name": "Twitter Access Token",
    "pattern": "[t|T][w|W][i|I][t|T][t|T][e|E][r|R].*[1-9][0-9]+-[0-9a-zA-Z]{40}"
  },
  {
    "name": "Twitter OAuth Secret",
    "pattern": "[t|T][w|W][i|I][t|T][t|T][e|E][r|R].*['|\"][0-9a-zA-Z]{35,44}['|\"]"
  },
  {
    "name": "AWS Secret Access Key Check",
    "pattern": "(?i)aws_secret_access_key\\s*[:=]\\s*['\"][0-9a-zA-Z/+=]{40}['\"]"
  }
]
